# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_USE_LOCAL_BOT_API=false
TELEGRAM_LOCAL_BOT_API_URL=http://localhost:8081

# Telegram Client API (для файлов > 20MB)
# Получите на https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_USE_CLIENT_API=true
TELEGRAM_SESSION_NAME=bot_session

# Access Control (оставьте пустым для доступа всем)
# Admin User IDs - список ID пользователей-администраторов (через запятую)
TELEGRAM_ADMIN_USER_IDS=1234,5678
# Allowed Chat IDs - список разрешенных чатов (личные чаты и группы, через запятую)
TELEGRAM_ALLOWED_CHAT_IDS=1234,5678

# Model Configuration
HF_TOKEN=your_huggingface_token_here
MODEL_DEVICE=cuda
DIARIZATION_DEVICE=cuda
ASR_BATCH_SIZE=32
DIARIZATION_BATCH_SIZE=32

# Processing Limits
MAX_AUDIO_DURATION_MINUTES=180
MAX_FILE_SIZE_MB=500
MAX_QUEUE_SIZE=50
MAX_USER_CONCURRENT=3
MAX_USER_PER_HOUR=10
PROCESSING_TIMEOUT_MINUTES=30

# Memory Management
MAX_VRAM_GB=14.0
CHUNK_DURATION_MINUTES=10
SEGMENT_MAX_SECONDS=30

# Paths
TEMP_DIR=./temp
LOG_DIR=./logs
CHECKPOINT_DIR=./temp/checkpoints

# Development
DEBUG=false
HOT_RELOAD=false
LOG_LEVEL=INFO
